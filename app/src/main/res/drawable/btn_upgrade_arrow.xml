<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true">
        <shape android:shape="rectangle">

            <solid android:color="#1B6B28"/>

            <stroke
                android:width="2dp"
                android:color="#8CFF9A"/>

            <corners android:radius="5dp"/>

            <padding
                android:left="2dp"
                android:top="2dp"
                android:right="2dp"
                android:bottom="2dp"/>
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">

            <solid android:color="#12501D"/>

            <stroke
                android:width="2dp"
                android:color="#35D84F"/>

            <corners android:radius="5dp"/>

            <padding
                android:left="2dp"
                android:top="2dp"
                android:right="2dp"
                android:bottom="2dp"/>
        </shape>
    </item>

</selector>