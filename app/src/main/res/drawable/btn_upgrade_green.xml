<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true">
        <shape android:shape="rectangle">

            <solid android:color="#103D17"/>

            <stroke
                android:width="2dp"
                android:color="#5CFF72"/>

            <corners android:radius="5dp"/>

            <padding
                android:left="4dp"
                android:top="2dp"
                android:right="4dp"
                android:bottom="2dp"/>
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">

            <solid android:color="#081B0C"/>

            <stroke
                android:width="2dp"
                android:color="#2FB545"/>

            <corners android:radius="5dp"/>

            <padding
                android:left="4dp"
                android:top="2dp"
                android:right="4dp"
                android:bottom="2dp"/>
        </shape>
    </item>

</selector>