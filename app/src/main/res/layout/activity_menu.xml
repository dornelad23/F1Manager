<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_menu_clean"
        android:scaleType="centerCrop" />

    <com.example.f1manager.DiagonalPanelView
        android:layout_width="470dp"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingTop="18dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="F1"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="46sp"
                android:fontFamily="sans-serif-black" />

            <View
                android:layout_width="145dp"
                android:layout_height="3dp"
                android:background="#D40000"
                android:layout_marginTop="-4dp"
                android:layout_marginBottom="3dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MANAGER"
                android:textColor="#E00000"
                android:textStyle="bold"
                android:textSize="18sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.20" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SEU LEGADO. SUA ESTRATÉGIA."
                android:textColor="#D8D8D8"
                android:textSize="8sp"
                android:letterSpacing="0.14"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <include
            android:id="@+id/btnJogar"
            layout="@layout/item_menu_jogar" />

        <include
            android:id="@+id/btnOpcoes"
            layout="@layout/item_menu_opcoes" />

        <include
            android:id="@+id/btnSair"
            layout="@layout/item_menu_sair" />

    </LinearLayout>

    <TextView
        android:text="VERSÃO 0.1.0    ALPHA"
        android:textColor="#AAAAAA"
        android:textSize="9sp"
        android:letterSpacing="0.12"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="28dp"
        android:layout_marginBottom="4dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

</FrameLayout>