<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_game">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:padding="28dp"
        android:gravity="center_vertical">

        <!-- LADO ESQUERDO: MENU DO JOGO -->
        <LinearLayout
            android:layout_width="340dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:padding="22dp"
            android:background="@drawable/card_game">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="F1 MANAGER"
                android:textColor="#FFFFFF"
                android:textSize="36sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TEMPORADA 2026"
                android:textColor="#FF1744"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="22dp" />

            <EditText
                android:id="@+id/editEmail"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Email"
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:background="@drawable/input_game"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginBottom="10dp" />

            <EditText
                android:id="@+id/editSenha"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Senha"
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:inputType="textPassword"
                android:background="@drawable/input_game"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginBottom="18dp" />

            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="CONTINUAR"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_game_red" />

            <Button
                android:id="@+id/btnCadastro"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="NOVA EQUIPE"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginTop="10dp"
                android:background="@drawable/btn_game_dark" />

        </LinearLayout>

        <!-- LADO DIREITO: VISUAL DE JOGO -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="30dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MONTE SUA EQUIPE"
                android:textColor="#FFFFFF"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="520dp"
                android:layout_height="wrap_content"
                android:text="Contrate pilotos, melhore seu carro e vença corridas simuladas em tempo real."
                android:textColor="#CCCCCC"
                android:textSize="17sp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="28dp" />

            <LinearLayout
                android:layout_width="520dp"
                android:layout_height="130dp"
                android:orientation="horizontal"
                android:padding="18dp"
                android:gravity="center_vertical"
                android:background="@drawable/card_game">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🏎️\nCARRO NÍVEL 1"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Velocidade  62\nControle      55\nPneu           48"
                    android:textColor="#DDDDDD"
                    android:textSize="16sp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>