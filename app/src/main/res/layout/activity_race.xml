<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/raceRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#07090D">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_race"
        android:scaleType="centerCrop" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#55000000" />

    <!-- TOPO -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="62dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="#99000000">

        <TextView
            android:id="@+id/txtVolta"
            android:layout_width="120dp"
            android:layout_height="46dp"
            android:gravity="center"
            android:text="VOLTA 1/20"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="14sp"
            android:background="@drawable/bg_topbar" />

        <TextView
            android:id="@+id/txtPosicao"
            android:layout_width="90dp"
            android:layout_height="46dp"
            android:layout_marginStart="10dp"
            android:gravity="center"
            android:text="P 10"
            android:textColor="#39FF5A"
            android:textStyle="bold"
            android:textSize="18sp"
            android:background="@drawable/bg_topbar" />

        <TextView
            android:id="@+id/txtTempo"
            android:layout_width="140dp"
            android:layout_height="46dp"
            android:layout_marginStart="10dp"
            android:gravity="center"
            android:text="1:28.000"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="14sp"
            android:background="@drawable/bg_topbar" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/btnIniciarCorrida"
            android:layout_width="170dp"
            android:layout_height="46dp"
            android:gravity="center"
            android:text="INICIAR"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="15sp"
            android:background="@drawable/btn_upgrade_green" />
    </LinearLayout>

    <!-- RANKING -->
    <LinearLayout
        android:id="@+id/painelRanking"
        android:layout_width="260dp"
        android:layout_height="520dp"
        android:layout_marginStart="10dp"
        android:layout_marginTop="74dp"
        android:layout_marginBottom="20dp"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="#E0000000"
        android:padding="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:gravity="center"
            android:text="🏁 GRANDE PRÊMIO"
            android:textColor="#39FF5A"
            android:textStyle="bold"
            android:textSize="15sp"
            android:background="@drawable/bg_topbar" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/listaRanking"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="6dp" />

        </ScrollView>
    </LinearLayout>

    <!-- DIREITA -->
    <LinearLayout
        android:layout_width="190dp"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="82dp"
        android:layout_marginEnd="12dp"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/imgMiniMapa"
            android:layout_width="match_parent"
            android:layout_height="145dp"
            android:src="@drawable/ic_track"
            android:scaleType="fitCenter"
            android:background="#BB000000"
            android:padding="8dp" />

        <TextView
            android:id="@+id/txtPneus"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="PNEUS 100%"
            android:textColor="#39FF5A"
            android:textStyle="bold"
            android:textSize="13sp"
            android:background="@drawable/bg_topbar" />

        <TextView
            android:id="@+id/txtCombustivel"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="COMB. 100%"
            android:textColor="#FFD84A"
            android:textStyle="bold"
            android:textSize="13sp"
            android:background="@drawable/bg_topbar" />

        <TextView
            android:id="@+id/txtClima"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="CLIMA: SECO"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="12sp"
            android:background="@drawable/bg_topbar" />

        <TextView
            android:id="@+id/txtRitmo"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="RITMO NORMAL"
            android:textColor="#39FF5A"
            android:textStyle="bold"
            android:textSize="12sp"
            android:background="@drawable/bg_topbar" />
    </LinearLayout>
</FrameLayout>