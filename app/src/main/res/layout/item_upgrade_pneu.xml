<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="0dp"
    android:layout_height="match_parent"
    android:layout_weight="1"
    android:layout_marginStart="6dp"
    android:layout_marginEnd="6dp"
    android:orientation="vertical"
    android:padding="7dp"
    android:background="@drawable/bg_upgrade_card">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="PNEUS"
        android:textAlignment="center"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="15sp"
        android:fontFamily="monospace" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:src="@drawable/pneu_upgrade"
            android:scaleType="fitCenter" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.15"
            android:orientation="vertical"
            android:gravity="end|center_vertical">

            <!-- NIVEL -->
            <TextView
                android:id="@+id/txtNivelPneus"
                android:layout_width="78dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="NÍVEL 1"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="9sp"
                android:fontFamily="monospace" />

            <!-- BARRA -->
            <LinearLayout
                android:layout_width="78dp"
                android:layout_height="15dp"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <View
                    android:id="@+id/barPneus1"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="#35C846"/>

                <View
                    android:id="@+id/barPneus2"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="2dp"
                    android:background="#252525"/>

                <View
                    android:id="@+id/barPneus3"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="2dp"
                    android:background="#252525"/>

                <View
                    android:id="@+id/barPneus4"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="2dp"
                    android:background="#252525"/>

                <View
                    android:id="@+id/barPneus5"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="2dp"
                    android:background="#252525"/>
            </LinearLayout>

            <!-- BONUS -->
            <TextView
                android:layout_width="78dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="+10 ADERÊNCIA"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="8sp"
                android:fontFamily="monospace" />
        </LinearLayout>
    </LinearLayout>

    <!-- PREÇO -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="34dp"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/txtPrecoPneus"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="R$ 3.500"
            android:textColor="#39E246"
            android:textStyle="bold"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:background="@drawable/btn_upgrade_green" />

        <TextView
            android:id="@+id/btnUpgradePneus"
            android:layout_width="38dp"
            android:layout_height="match_parent"
            android:layout_marginStart="8dp"
            android:gravity="center"
            android:text="⬆"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="20sp"
            android:fontFamily="monospace"
            android:background="@drawable/btn_upgrade_arrow"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

</LinearLayout>