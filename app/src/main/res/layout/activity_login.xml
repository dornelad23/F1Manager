<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_menu_clean"
        android:scaleType="centerCrop" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="30dp"
        android:layout_marginTop="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="F1"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="46sp"
            android:fontFamily="sans-serif-black" />

        <View
            android:layout_width="145dp"
            android:layout_height="3dp"
            android:background="#D40000"
            android:layout_marginTop="-4dp"
            android:layout_marginBottom="3dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MANAGER"
            android:textColor="#E00000"
            android:textStyle="bold"
            android:textSize="18sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.20" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SEU LEGADO. SUA ESTRATÉGIA."
            android:textColor="#D8D8D8"
            android:textSize="8sp"
            android:letterSpacing="0.14"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="42dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selecione a forma de login"
            android:textColor="#DDDDDD"
            android:textSize="13sp"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/btnGoogle"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:gravity="center"
                android:text="G"
                android:textSize="30sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/login_square" />

            <TextView
                android:id="@+id/btnFacebook"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:gravity="center"
                android:text="f"
                android:textSize="36sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginStart="26dp"
                android:background="@drawable/login_square" />

            <TextView
                android:id="@+id/btnEmail"
                android:layout_width="180dp"
                android:layout_height="42dp"
                android:gravity="center"
                android:text="ENTRAR COM EMAIL"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="12sp"
                android:layout_marginTop="16dp"
                android:background="@drawable/login_square" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>