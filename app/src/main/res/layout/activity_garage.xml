<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050505">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:padding="32dp">

        <LinearLayout
            android:layout_width="300dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="22dp"
            android:background="@drawable/bg_login_box">

            <TextView
                android:id="@+id/txtNomeEquipe"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Equipe"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black" />

            <TextView
                android:id="@+id/txtDinheiro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R$ 0"
                android:textColor="#FF2A2A"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="GARAGEM"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/bg_btn_red"
                android:layout_marginTop="40dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="PILOTOS"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/bg_input"
                android:layout_marginTop="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="CORRIDA"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/bg_input"
                android:layout_marginTop="12dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="34dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SUA GARAGEM"
                android:textColor="#FFFFFF"
                android:textSize="34sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Melhore seu carro, evolua sua equipe e domine a temporada."
                android:textColor="#BBBBBB"
                android:textSize="15sp"
                android:layout_marginTop="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="230dp"
                android:layout_marginTop="28dp"
                android:padding="26dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_login_box">

                <TextView
                    android:id="@+id/txtCarroNivel"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:text="CARRO NÍVEL 1"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black" />

                <TextView
                    android:id="@+id/txtAtributos"
                    android:layout_width="260dp"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:text="Motor: 10\nVelocidade: 10\nControle: 10\nPneu: 10"
                    android:textColor="#DDDDDD"
                    android:textSize="18sp" />

            </LinearLayout>

            <TextView
                android:layout_width="240dp"
                android:layout_height="54dp"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:text="MELHORAR CARRO"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/bg_btn_red" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>