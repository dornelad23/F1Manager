<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/garageRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#10151B">

    <ImageView
        android:id="@+id/imgGarageBg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/garage_bg"
        android:scaleType="fitXY" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="62dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:background="#E6101419">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1.45"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:background="@drawable/bg_topbar">

                <ImageView
                    android:layout_width="27dp"
                    android:layout_height="27dp"
                    android:src="@drawable/logo_f1_manager" />

                <LinearLayout
                    android:id="@+id/cardEquipe"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="7dp"
                    android:orientation="vertical">



                    <TextView
                        android:id="@+id/txtNomeEquipe"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SAMUEL RACING"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="10sp"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/txtTemporadaEquipe"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Temporada 2026"
                        android:textColor="#D8D8D8"
                        android:textSize="8sp"
                        android:fontFamily="monospace" />
                </LinearLayout>
            </LinearLayout>

            <Space android:layout_width="68dp" android:layout_height="1dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1.18"
                android:gravity="center"
                android:orientation="vertical"
                android:background="@drawable/bg_topbar">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DINHEIRO"
                    android:textColor="#FFFFFF"
                    android:textSize="8sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/txtDinheiro"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R$ 50.000"
                    android:textColor="#39E246"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <Space android:layout_width="76dp" android:layout_height="1dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="0.72"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_topbar">

                <ImageView
                    android:layout_width="21dp"
                    android:layout_height="21dp"
                    android:src="@drawable/ic_calendar" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="TEMPORADA\n2026"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="8sp"
                    android:fontFamily="monospace"
                    android:gravity="center" />
            </LinearLayout>

            <Space android:layout_width="8dp" android:layout_height="1dp" />

            <LinearLayout
                android:id="@+id/cardRank"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="0.72"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_topbar">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_trophy" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="7dp"
                    android:text="RANK\n-"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="8sp"
                    android:fontFamily="monospace"
                    android:gravity="center" />
            </LinearLayout>

            <Space android:layout_width="14dp" android:layout_height="1dp" />

            <ImageButton
                android:id="@+id/btnConfig"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:padding="10dp"
                android:src="@drawable/ic_settings"
                android:background="@drawable/bg_topbar" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/btnVoltar"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:layout_marginTop="7dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingStart="9dp"
                android:paddingEnd="13dp"
                android:background="@drawable/bg_topbar">

                <ImageView
                    android:layout_width="19dp"
                    android:layout_height="19dp"
                    android:src="@drawable/ic_back" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="7dp"
                    android:text="VOLTAR"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <ImageView
                android:id="@+id/imgCarro"
                android:layout_width="635dp"
                android:layout_height="205dp"
                android:layout_gravity="center_horizontal|bottom"
                android:layout_marginBottom="-40dp"
                android:src="@drawable/carro_pixel"
                android:scaleType="fitCenter" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/areaUpgrades"
            android:layout_width="match_parent"
            android:layout_height="154dp"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingBottom="8dp">

            <include layout="@layout/item_upgrade_motor" />
            <include layout="@layout/item_upgrade_aero" />
            <include layout="@layout/item_upgrade_pneu" />
            <include layout="@layout/item_upgrade_controle" />

        </LinearLayout>
    </LinearLayout>
</FrameLayout>